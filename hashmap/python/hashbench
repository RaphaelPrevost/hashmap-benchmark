#!/usr/bin/env python3
import sys

def main():
    if len(sys.argv) != 3:
        return 1

    mode = sys.argv[1]
    try:
        n = int(sys.argv[2])
    except ValueError:
        return 1

    d = {}
    missing = 0

    if mode in ("insert", "update", "retrieve", "miss"):
        # Populate map first so retrieve/miss can validate against it.
        for i in range(1, n + 1):
            key = f"{i}"
            d[key] = i

        if mode == "retrieve":
            for i in range(1, n + 1):
                key = f"{i}"
                if d.get(key) != i:
                    missing += 1

        elif mode == "update":
            for i in range(1, n + 1):
                key = f"{i}"
                d[key] = i + 1

        elif mode == "miss":
            for i in range(1, n + 1):
                key = f"B{i}"
                if key in d:
                    missing += 1

        return 0 if missing == 0 else 1

    return 1

if __name__ == "__main__":
    sys.exit(main())
